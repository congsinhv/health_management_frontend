              <span className='text-sm'>7</span>
            </TabsTrigger>
          </TabsList>
        </div>
        {[1, 2, 3, 4, 5, 6, 7].map(day => (
          <TabsContent key={day} value={`DAY_${day}`}>
            {currentDayPlan && (
              <div className='grid grid-cols-3 gap-4'>
