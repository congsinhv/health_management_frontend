                  )}
                  value={editContent}
                  onChange={e => setEditContent(e.target.value)}
                  onKeyDown={handleEditKeyDown}
                  maxLength={500}
                  autoFocus
                />
                <div className='flex items-center justify-between gap-3'>
                  <span
                    className={cn(
