                </PopoverTrigger>
                <PopoverContent
                  align='end'
                  className='w-[180px] rounded-lg border border-gray-200 bg-white p-2 shadow-lg md:w-[160px]'
                >
                  <div className='flex flex-col gap-1'>
                    <button
                      onClick={handleProfile}
